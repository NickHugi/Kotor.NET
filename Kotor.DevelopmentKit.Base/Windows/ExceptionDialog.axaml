<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Kotor.DevelopmentKit.Base.ViewModels"
        x:Class="Kotor.DevelopmentKit.Base.ExceptionDialog"
        x:DataType="vm:ExceptionDialogViewModel"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
        Width="400" Height="250"
        Title="An error occured">
    <Grid RowDefinitions="Auto,5,*,5,Auto" Margin="5">
        <TextBlock Grid.Row="0" Text="{Binding Message}"/>
        <TextBox Grid.Row="2" IsReadOnly="False" Text="{Binding Exception.StackTrace}"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="5">
            <Button>Ok</Button>
            <Button>Copy</Button>
        </StackPanel>
    </Grid>
</Window>
