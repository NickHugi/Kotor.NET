<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Kotor.DevelopmentKit.Base.ViewModels"
        x:Class="Kotor.DevelopmentKit.Base.ExceptionDialog"
        x:DataType="vm:ExceptionDialogViewModel"
        x:Name="Window"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
        Width="400" SizeToContent="Height" MaxHeight="400"
        Title="An error occured">
    <Grid RowDefinitions="*,5,*,5,Auto" Margin="5">
        <TextBlock Grid.Row="0" Text="{Binding Message}" TextWrapping="Wrap"/>
        <TextBox Grid.Row="2" IsReadOnly="True" Text="{Binding StackTrace}" TextWrapping="Wrap"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="5">
            <Button Command="{Binding #Window.Ok}">Ok</Button>
            <Button Command="{Binding #Window.Copy}">Copy</Button>
        </StackPanel>
    </Grid>
</Window>
