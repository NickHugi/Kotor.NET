<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             xmlns:base-views="clr-namespace:Kotor.DevelopmentKit.Base.Views;assembly=Kotor.DevelopmentKit.Base"
             xmlns:base-converters="clr-namespace:Kotor.DevelopmentKit.Base.ValueConverters;assembly=Kotor.DevelopmentKit.Base"
             xmlns:base-extensions="clr-namespace:Kotor.DevelopmentKit.Base.Extensions;assembly=Kotor.DevelopmentKit.Base"
             
             xmlns:views="clr-namespace:Kotor.DevelopmentKit.Base.Views"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="30"
             x:Class="Kotor.DevelopmentKit.Base.Views.IntegerUpDown">

    <UserControl.Resources>
        <base-converters:IntegerConverter x:Key="IntegerConverter"/>
    </UserControl.Resources>
    
    <Grid ColumnDefinitions="*, 30, 30">
        <TextBox Text="{Binding $parent[views:IntegerUpDown].Value, Converter={StaticResource IntegerConverter}, ConverterParameter=Min:0, Mode=TwoWay}"
                 Grid.Column="0"
                 Name="IntegerTextBox"/>
        <Button Grid.Column="1" HorizontalAlignment="Stretch">-</Button>
        <Button Grid.Column="2" HorizontalAlignment="Stretch">+</Button>
    </Grid>
</UserControl>
