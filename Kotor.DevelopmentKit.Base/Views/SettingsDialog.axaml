<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        
        xmlns:vm="using:Kotor.DevelopmentKit.Base.ViewModels"
        xmlns:pages="using:Kotor.DevelopmentKit.Base.Settings.Pages"

        xmlns:boolean-vm="using:Kotor.DevelopmentKit.Base.Settings.Types.Boolean"
        xmlns:boolean-view="clr-namespace:Kotor.DevelopmentKit.Base.Settings.Types.Boolean"

        xmlns:integer-vm="using:Kotor.DevelopmentKit.Base.Settings.Types.Integer"
        xmlns:integer-view="clr-namespace:Kotor.DevelopmentKit.Base.Settings.Types.Integer"
        
        xmlns:string-vm="using:Kotor.DevelopmentKit.Base.Settings.Types.String"
        xmlns:string-view="clr-namespace:Kotor.DevelopmentKit.Base.Settings.Types.String"
        
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="vm:SettingsDialogViewModel"
        x:Class="Kotor.DevelopmentKit.Base.SettingsDialog">
    <DockPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <TreeView DockPanel.Dock="Left" BorderThickness="1" BorderBrush="Black" ItemsSource="{Binding Pages}"
                  Width="600" SelectedItem="{Binding SelectedPage}">
            <TreeView.DataTemplates>
                <TreeDataTemplate DataType="{x:Type pages:SettingsPageViewModel}" ItemsSource="{Binding Pages}">
                    <TextBlock Text="{Binding Name}" />
                </TreeDataTemplate>
            </TreeView.DataTemplates>
        </TreeView>
        <ScrollViewer DockPanel.Dock="Right" HorizontalAlignment="Stretch">
            <ItemsControl ItemsSource="{Binding SelectedPage.Properties}" Margin="25">
                <ItemsControl.DataTemplates>
                    <DataTemplate DataType="{x:Type boolean-vm:BooleanPanelViewModel}">
                        <boolean-view:BooleanPanel Margin="0 0 0 25" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type integer-vm:IntegerPanelViewModel}">
                        <integer-view:IntegerPanel Margin="0 0 0 25" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type string-vm:StringPanelViewModel}">
                        <string-view:StringPanel Margin="0 0 0 25" />
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
