<MenuItem xmlns="https://github.com/avaloniaui"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="200"

          Name="MenuItem"
          Header="_Set Installation"
          
          xmlns:collection="using:System.Collections.Generic"
          xmlns:vm="using:Kotor.DevelopmentKit.Base.Settings.Values"
           
          x:DataType="{x:Type collection:ICollection, x:TypeArguments=vm:InstallationSettings}"
          x:Class="Kotor.DevelopmentKit.Base.Settings.Views.SelectInstallationMenuItem"
          />
