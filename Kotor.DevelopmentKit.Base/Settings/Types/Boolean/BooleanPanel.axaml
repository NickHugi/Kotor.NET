
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Kotor.DevelopmentKit.Base.Settings.Types.Boolean"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="50"
             x:DataType="vm:BooleanPanelViewModel"
             x:Class="Kotor.DevelopmentKit.Base.Settings.Types.Boolean.BooleanPanel">
    <StackPanel Spacing="2">
        <TextBlock FontWeight="Bold"
                   Text="{Binding Name}"
                   />
        <CheckBox IsChecked="{Binding Value}">
            <TextBlock Text="{Binding Description}"
                       TextWrapping="Wrap"
                       />
        </CheckBox>
    </StackPanel>
</UserControl>
