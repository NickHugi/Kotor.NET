
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Kotor.DevelopmentKit.Base.Settings.Types.Integer"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="50"
             x:DataType="vm:IntegerPanelViewModel"
             x:Class="Kotor.DevelopmentKit.Base.Settings.Types.Integer.IntegerPanel">
    <StackPanel Spacing="2">
        <TextBlock FontWeight="Bold" Text="{Binding Name}" />
        <TextBlock Text="{Binding Description}" VerticalAlignment="Center" />
        <NumericUpDown Value="{Binding Value}" />
    </StackPanel>
</UserControl>
