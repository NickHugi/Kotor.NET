<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             xmlns:vm="clr-namespace:Kotor.DevelopmentKit.EditorGFF.ViewModels.FieldPanel"
             
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="300"
             x:Class="Kotor.DevelopmentKit.EditorGFF.Views.FieldVector4Panel"
             x:DataType="vm:Vector4PanelViewModel"
             x:Name="Control">
    <Border Background="#eee" BorderBrush="#ddd" BorderThickness="1" CornerRadius="4" Padding="10">
        <StackPanel>
            <TextBlock Foreground="Gray">X</TextBlock>
            <NumericUpDown Value="{Binding Value.X}" ParsingNumberStyle="Float" LostFocus="NumericUpDown_LostFocus" />

            <TextBlock Foreground="Gray">Y</TextBlock>
            <NumericUpDown Value="{Binding Value.Y}" ParsingNumberStyle="Float" LostFocus="NumericUpDown_LostFocus" />

            <TextBlock Foreground="Gray">Z</TextBlock>
            <NumericUpDown Value="{Binding Value.Z}" ParsingNumberStyle="Float" LostFocus="NumericUpDown_LostFocus" />

            <TextBlock Foreground="Gray">W</TextBlock>
            <NumericUpDown Value="{Binding Value.W}" ParsingNumberStyle="Float" LostFocus="NumericUpDown_LostFocus" />
        </StackPanel>
    </Border>
</UserControl>
