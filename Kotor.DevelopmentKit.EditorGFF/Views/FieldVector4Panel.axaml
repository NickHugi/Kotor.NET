<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="300"
             x:Class="Kotor.DevelopmentKit.EditorGFF.Views.FieldVector4Panel"
             x:Name="Control">
    <StackPanel>
        <TextBlock Foreground="Gray">X</TextBlock>
        <NumericUpDown Value="{Binding #Control.CurrentValue.X}" ParsingNumberStyle="Float" />

        <TextBlock Foreground="Gray">Y</TextBlock>
        <NumericUpDown Value="{Binding #Control.CurrentValue.Y}" ParsingNumberStyle="Float" />

        <TextBlock Foreground="Gray">Z</TextBlock>
        <NumericUpDown Value="{Binding #Control.CurrentValue.Z}" ParsingNumberStyle="Float" />

        <TextBlock Foreground="Gray">W</TextBlock>
        <NumericUpDown Value="{Binding #Control.CurrentValue.W}" ParsingNumberStyle="Float" />
    </StackPanel>
</UserControl>
