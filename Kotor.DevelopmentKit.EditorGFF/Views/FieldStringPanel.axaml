<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             xmlns:vm="using:Kotor.DevelopmentKit.EditorGFF.ViewModels.GFFTreeNodes"
             
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="300"
             x:Class="Kotor.DevelopmentKit.EditorGFF.Views.FieldStringPanel"
             x:DataType="vm:StringGFFTreeNodeViewModel">
    <StackPanel>
        <TextBlock Foreground="Gray">Value</TextBlock>
        <TextBox Text="{Binding FieldValue, Mode=TwoWay}" AcceptsReturn="True" />
    </StackPanel>
</UserControl>
