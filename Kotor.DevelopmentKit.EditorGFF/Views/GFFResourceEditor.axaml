<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kotor.DevelopmentKit.EditorGFF.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="800" Height="450"
        x:Class="Kotor.DevelopmentKit.EditorGFF.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Kotor.DevelopmentKit.EditorGFF">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="10" ColumnDefinitions="*, 300">
        <TreeDataGrid Name="TreeDataGrid"
                      Source="{Binding TreeData}"
                      PointerPressed="TreeDataGrid_PointerPressed"
                      Grid.Column="0"
                      />

        <StackPanel Orientation="Vertical" Spacing="5" Grid.Column="1" Margin="10 0 0 0">
            <StackPanel Orientation="Vertical">
                <TextBlock Foreground="Gray">Type</TextBlock>
                <TextBox />
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Foreground="Gray">Label</TextBlock>
                <TextBox />
            </StackPanel>
            
        </StackPanel>
        
    </Grid>

</Window>
