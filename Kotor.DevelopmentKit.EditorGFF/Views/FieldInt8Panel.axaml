<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             xmlns:vm="clr-namespace:Kotor.DevelopmentKit.EditorGFF.ViewModels.FieldPanel"
             
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="300"
             x:Class="Kotor.DevelopmentKit.EditorGFF.Views.FieldInt8Panel"
             x:DataType="vm:Int8PanelViewModel"
             x:Name="Control">
    <Border Background="#eee" BorderBrush="#ddd" BorderThickness="1" CornerRadius="4" Padding="10">
        <StackPanel>
            <TextBlock Foreground="Gray">Value</TextBlock>
            <NumericUpDown Value="{Binding #Control.CurrentValue, Mode=TwoWay}" Minimum="-128" Maximum="127" FormatString="N0" ParsingNumberStyle="Integer" LostFocus="NumericUpDown_LostFocus" />
        </StackPanel>
    </Border>
</UserControl>
